# Copy to .env.local (gitignored) for `npm run dev`.
#
# In deployed forks, these are NOT read from a committed file — they are injected
# as Docker build-args from that fork's GitHub repo Variables (Settings > Secrets
# and variables > Actions > Variables). See RUNBOOK.md.

NEXT_PUBLIC_API_URL=https://your-api.example.com
NEXT_PUBLIC_STORE_ID=your-store-uuid-here
NEXT_PUBLIC_STORE_NAME=My Store
